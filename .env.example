# mcp-pdf-rs environment configuration
# Copy this file to .env and fill in your values (or set vars in your shell).

# ── Transport ──────────────────────────────────────────────────────────────────
# Transport protocol: stdio (default, for Claude Desktop) or http
# MCP_PDF_TRANSPORT=stdio

# When MCP_PDF_TRANSPORT=http:
# MCP_PDF_HTTP_HOST=0.0.0.0
# MCP_PDF_HTTP_PORT=8080

# ── Engine ─────────────────────────────────────────────────────────────────────
# PDF engine: native (default) or stirling
# MCP_PDF_ENGINE=native

# ── Stirling PDF bridge (optional) ────────────────────────────────────────────
# Required to enable OCR, watermarking, and image conversion tools.
# The binary must also be built with --features stirling-bridge.

# STIRLING_PDF_URL=http://localhost:8080
# STIRLING_PDF_API_KEY=your-api-key-here
# STIRLING_PDF_TIMEOUT=120
